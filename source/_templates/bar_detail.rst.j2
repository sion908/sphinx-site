{{ '=' * 30 }}
{{ bar.name }}
{{ '=' * 30 }}

.. raw:: html

   <div class="bar-detail">
     <div class="bar-detail__hero">
       {% if bar.image_url %}
       <img class="bar-detail__image" src="{{ bar.image_url }}" alt="{{ bar.name }}">
       {% else %}
       <div class="bar-detail__placeholder">BAR</div>
       {% endif %}
       <div class="bar-detail__summary">
         <p class="bar-detail__category">{{ bar.category }}</p>
         <h1 class="bar-detail__title">{{ bar.name }}</h1>
         <p class="bar-detail__desc">{{ bar.description }}</p>
         <dl class="bar-detail__meta">
           <dt>エリア</dt><dd>{{ bar.area }}</dd>
           <dt>営業時間</dt><dd>{{ bar.hours }}</dd>
           <dt>定休日</dt><dd>{{ bar.closed }}</dd>
           <dt>住所</dt><dd>{{ bar.address }}</dd>
         </dl>
         <div class="bar-detail__links">
           {% if bar.website_url %}<a href="{{ bar.website_url }}">Web</a>{% endif %}
           {% if bar.instagram_url %}<a href="{{ bar.instagram_url }}">Instagram</a>{% endif %}
           {% if bar.x_url %}<a href="{{ bar.x_url }}">X</a>{% endif %}
         </div>
         <div class="bar-detail__tags">
           {% for tag in bar.tags %}
           <span class="bar-tag">{{ tag }}</span>
           {% endfor %}
         </div>
       </div>
     </div>
   </div>

