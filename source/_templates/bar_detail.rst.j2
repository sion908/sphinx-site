{{ '=' * 30 }}
{{ bar.name }}
{{ '=' * 30 }}

.. raw:: html

   <div class="bar-detail">
     <div class="bar-detail__hero">
       {% if bar.image_url %}
       <img class="bar-detail__image" src="{{ bar.image_url }}" alt="{{ bar.name }}">
       {% else %}
       <div class="bar-detail__placeholder">🍸</div>
       {% endif %}
       <div class="bar-detail__summary">
         <h1 class="bar-detail__title">{{ bar.name }}</h1>
         <dl class="bar-detail__meta">
           <dt>営業時間</dt><dd>{{ bar.hours }}</dd>
         </dl>
         {% if bar.promotion %}
         <p class="bar-detail__desc">{{ bar.promotion }}</p>
         {% endif %}
         {% if bar.sns_links %}
         <div class="bar-detail__links">
           {% for link in bar.sns_links %}
           <a href="{{ link }}" target="_blank">{{ link }}</a>
           {% endfor %}
         </div>
         {% endif %}
       </div>
     </div>
   </div>

